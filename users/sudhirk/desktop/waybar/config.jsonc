// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "bottom",
    "height": 0,

    "modules-left": [
        "group/internet",
        "custom/rtriangle1",
        "backlight",
        "custom/rtriangle2",
        "pulseaudio",
        "custom/rtriangle3",
        "niri/window",
    ],

    // "modules-center": [
    //     "cava",
    // ],

    "modules-right": [
        "custom/ltriangle2",
        "group/power",
        "custom/ltriangle1",
        "group/time"
    ],

    "group/time": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 700,
            "transition-left-to-right": false,
        },
        "modules": [
            "clock",
            "clock#full",
        ] 
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%I:%M} ´É║ ",
        "interval": 60
    },

    "clock#full": {
        "format": "{:%A, %d-%m-%Y (%B)}",
        "interval": 3600
    },

