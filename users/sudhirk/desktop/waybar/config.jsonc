    //     "noise_reduction": 0.77,
    //     "input_delay": 2,
    //     "format-icons": [" ", " ", "Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", ],
    //     "actions": {
    //                "on-click-right": "mode"
    //                }
    // },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}´èö",
        "format-muted": "´Çª",
        "format-icons": {
            "alsa_output.pci-0000_00_1f.3.analog-stereo": "¯î¡",
            "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "¯╗¿¯î¡",
            "headphone": "´ÇÑ",
            "hands-free": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "phone-muted": "¯┤ù",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çº", "´Ç¿"]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": ["Easy Effects Sink"]
    },

    "group/internet": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 700,
            "transition-left-to-right": true,
        },
        "modules": [
            "network",
            "network#essid",
            "network#ip"
        ] 
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "¾▒Ü¢ ",
        "format-ethernet": "{ipaddr}/{cidr} ´×û",
        //"tooltip-format": "{ifname} via {gwaddr} ",
        "tooltip-format": "{essid}: {ipaddr}",
        "format-linked": "{ifname} (No IP) ´×û",
        "format-disconnected": "¾▒øà ",
        //"format-alt": "{ifname}: {ipaddr}/{cidr}: {essid}",
        "on-click": "kitty nmtui",
    },

    "network#essid": {
        "format-wifi": "{essid} ({signalStrength}%)",
    },

    "network#ip": {
        "format-wifi": "{ipaddr}",
    },

    "backlight": { "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["´åà", "´äæ"]
    },

    "niri/window": { 
        "tooltip": false,
        "format": "",
        "on-click": "niri msg action toggle-overview",
    },

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false,
        },
        "modules": [
            "battery",
            "battery#timeruntil",
            "battery#currentpower",
        ] 
    },

    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon} ",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "max-length": 25,
        "format-charging": "{capacity}% ´çª ",
        "format-plugged": "{capacity}% ¯¼¡ ",
    },

    "battery#timeruntil": {
        "interval": 300,
        "full-at": 80,
        "format-time": "{H}h {M}m",
        "format": "{time} ´ëö",
        "format-plugged": "¾░öô",
    },

    "battery#currentpower": {
        "interval": 10,
        "format": "{power}W ¾▒Éï",
        "format-plugged": "¾▒ñü",
    },


    "custom/ltriangle1": {
		"format": "¯é║",
		"tooltip": false
	},

    "custom/ltriangle2": {
		"format": "¯é║",
		"tooltip": false
	},

    "custom/rtriangle1": {
        "format": "¯é©",
        "tooltip": false
    },

    "custom/rtriangle2": {
		"format": "¯é©",
		"tooltip": false
	},

    "custom/rtriangle3": {
		"format": "¯é©",
		"tooltip": false
	},

}

